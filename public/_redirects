# API must precede SPA catch-all — without this line, `/api/*` never reaches Functions.
/api/send-mail    /.netlify/functions/send-mail    200

# Trailing slashes → canonical URLs (contact cards / QR codes)
/services/    /services    301!
/about/       /about       301!
/team/        /team        301!
/portfolio/   /portfolio   301!
/contact/     /contact     301!
/form/        /form        301!
/contact/:slug/    /contact/:slug    301!
/menu/:slug/       /menu/:slug       301!

# Never SPA-fallback asset files (prevents HTML being saved as PDF/etc.)
/assets/*    /assets/:splat    200

# Legacy PDF filenames (old spaced names from first deploy)
/assets/pdf/WATAD%20Agro%20AR.pdf    /assets/pdf/watad-agro-portfolio.pdf    301!
/assets/pdf/crazy%20beeez%20portfolio.pdf    /assets/pdf/crazy-beeez-portfolio.pdf    301!

/*    /index.html   200
