# ── CRA (browser) ── Optional
REACT_APP_CONTACT_EMAIL=info@elyptek.com

# Local dev (`npm start` + `npm run functions`): defaults to http://127.0.0.1:9999
# NETLIFY_FUNCTIONS_TARGET=http://127.0.0.1:9999

# ── Netlify (dashboard → Environment variables) — don't use REACT_APP_ for SMTP secrets ──
MAIL_TO=info@elyptek.com
MAIL_FROM=info@elyptek.com

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional: comma-separated origins for CORS (browser forms on another host / previews)
ALLOWED_ORIGINS=https://your-site.netlify.app,http://localhost:8888
